# MiniMax 中转 profile —— 推荐用 `cca init minimax` 生成(自动 chmod 600,CC_KEY=xxx 可注入)。
# 各键含义见 README《第三方中转》。

ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=在此填你的MiniMaxKEY

# 模型映射:Claude 大/中/小三档 → 中转模型
ANTHROPIC_DEFAULT_OPUS_MODEL=MiniMax-M3[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M3[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M3[1m]

# 触发自动压缩的上下文窗口大小(配合上面 [1m] 大窗口模型;不确定就别动)
CLAUDE_CODE_AUTO_COMPACT_WINDOW=1000000

# 可选代理(MiniMax 国内直连,通常不需要;宿主机代理写 host.docker.internal,不能写 127.0.0.1)
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
